# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=payments
POSTGRES_PASSWORD=payments_secret
POSTGRES_DB=payments

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=payments
RABBITMQ_PASSWORD=payments_secret
RABBITMQ_VHOST=/

# App
API_KEY=dev_secret_key_change_in_production
LOG_LEVEL=INFO
ENVIRONMENT=development

# Outbox
OUTBOX_POLL_INTERVAL=1.0

# Gateway emulator
GATEWAY_SUCCESS_RATE=0.9
GATEWAY_MIN_DELAY=2.0
GATEWAY_MAX_DELAY=5.0

# Webhook retry
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_BACKOFF=2.0
